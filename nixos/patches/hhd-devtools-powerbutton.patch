+def _call_devtools(expr: str) -> bool:
+    """Evaluate a JS expression in Steam's SharedJSContext via Chrome DevTools."""
+    try:
+        import urllib.request
+
+        resp = urllib.request.urlopen(
+            f"http://127.0.0.1:{DEVTOOLS_PORT}/json", timeout=2
+        )
+        targets = json.loads(resp.read())
+        ws_url = None
+        for t in targets:
+            if t.get("title") == "SharedJSContext":
+                ws_url = t.get("webSocketDebuggerUrl")
+                break
+        if not ws_url:
+            logger.error("DevTools: SharedJSContext not found")
+            return False
+
+        # Parse ws://host:port/path
+        url = ws_url.replace("ws://", "")
+        hp, path = url.split("/", 1)
+        host, port = hp.split(":")
+
+        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
+        sock.settimeout(5)
+        sock.connect((host, int(port)))
+
+        key = base64.b64encode(os.urandom(16)).decode()
+        sock.sendall(
+            f"GET /{path} HTTP/1.1\r\nHost: {host}:{port}\r\n"
+            f"Upgrade: websocket\r\nConnection: Upgrade\r\n"
+            f"Sec-WebSocket-Key: {key}\r\nSec-WebSocket-Version: 13\r\n\r\n"
+            .encode()
+        )
+        r = b""
+        while b"\r\n\r\n" not in r:
+            chunk = sock.recv(4096)
+            if not chunk:
+                sock.close()
+                return False
+            r += chunk
+
+        # Send as masked WebSocket text frame
+        payload = json.dumps(
+            {"id": 1, "method": "Runtime.evaluate",
+             "params": {"expression": expr}}
+        ).encode()
+        frame = bytearray([0x81])
+        mask_key = os.urandom(4)
+        plen = len(payload)
+        if plen < 126:
+            frame.append(0x80 | plen)
+        elif plen < 65536:
+            frame.append(0x80 | 126)
+            frame.extend(struct.pack(">H", plen))
+        else:
+            frame.append(0x80 | 127)
+            frame.extend(struct.pack(">Q", plen))
+        frame.extend(mask_key)
+        frame.extend(
+            bytearray(b ^ mask_key[i % 4] for i, b in enumerate(payload))
+        )
+        sock.sendall(frame)
+
+        try:
+            sock.settimeout(2)
+            sock.recv(4096)
+        except socket.timeout:
+            pass
+        sock.close()
+        logger.info(f"DevTools: evaluated '{expr}'")
+        return True
+    except Exception as e:
+        logger.error(f"DevTools call failed: {e}")
+        return False
+
