+static bool asus_kbd_backlight_init_retryable(int ret)
+{
+	return ret == -EPIPE || ret == -ETIMEDOUT || ret == -EIO;
+}
+
+static void asus_kbd_schedule_backlight_retry(struct hid_device *hdev, int ret)
+{
+	struct asus_drvdata *drvdata = hid_get_drvdata(hdev);
+
+	if (!(drvdata->quirks & QUIRK_ZENBOOK_DUO_KEYBOARD) ||
+	    !asus_kbd_backlight_init_retryable(ret)) {
+		hid_warn(hdev, "Failed to initialize backlight: %d\n", ret);
+		return;
+	}
+
+	if (drvdata->kbd_backlight_init_retries >= ZENBOOK_DUO_KBD_INIT_RETRIES) {
+		hid_warn(hdev, "Failed to initialize backlight after %u retries: %d\n",
+			 drvdata->kbd_backlight_init_retries, ret);
+		return;
+	}
+
+	drvdata->kbd_backlight_init_retries++;
+	hid_warn(hdev, "Failed to initialize backlight (%d), retry %u/%u scheduled\n",
+		 ret, drvdata->kbd_backlight_init_retries,
+		 ZENBOOK_DUO_KBD_INIT_RETRIES);
+	schedule_delayed_work(&drvdata->kbd_backlight_init_work,
+			      msecs_to_jiffies(ZENBOOK_DUO_KBD_INIT_RETRY_DELAY_MS));
+}
+
+static void asus_kbd_backlight_init_work(struct work_struct *work)
+{
+	struct asus_drvdata *drvdata = container_of(to_delayed_work(work),
+					       struct asus_drvdata,
+					       kbd_backlight_init_work);
+	struct hid_device *hdev = drvdata->hdev;
+	int ret;
+
+	if (drvdata->kbd_backlight)
+		return;
+
+	ret = asus_kbd_register_leds(hdev);
+	if (ret < 0) {
+		asus_kbd_schedule_backlight_retry(hdev, ret);
+		return;
+	}
+
+	hid_info(hdev, "Initialized keyboard backlight after retry\n");
+
+	if (drvdata->quirks & QUIRK_HID_FN_LOCK) {
+		ret = asus_kbd_set_fn_lock(hdev, drvdata->fn_lock);
+		if (ret < 0)
+			hid_warn(hdev, "Failed to resync Fn lock after retry: %d\n", ret);
+	}
+}
 
