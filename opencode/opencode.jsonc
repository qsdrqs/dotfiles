{
  "plugin": [
    "oh-my-openagent@3.15.3",
    "opencode-claude-auth",
    "opencode-gemini-auth@latest",
    "opencode-websearch-cited@1.2.0"
  ],
  "$schema": "https://opencode.ai/config.json",
  "formatter": false,
  "model": "{env:OPENCODE_MODEL}",
  "compaction": {
    "auto": false
  },
  "snapshot": false,
  "agent": {
    "researcher": {
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "prompt": "{file:./skills/researcher/SKILL.md}",
      "tools": {
        "*": true
      }
    }
  },
  "share": "disabled",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ]
    },
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@brave/brave-search-mcp-server",
        "--transport",
        "stdio"
      ]
    }
  },
  "provider": {
    "openrouter": {
      "models": {
        "z-ai/glm-5": {
          "options": {
            "provider": {
              "order": [
                "novita/fp8",
                "z-ai"
              ],
              "allow_fallbacks": false
            }
          }
        },
        "openai/gpt-oss-20b": {
          "options": {
            "provider": {
              "order": [
                "groq"
              ],
              "allow_fallbacks": false
            }
          }
        },
        "openai/gpt-oss-120b": {
          "options": {
            "provider": {
              "order": [
                "cerebras"
              ],
              "allow_fallbacks": false
            }
          }
        },
        "minimax/minimax-m2.1": {
          "options": {
            "provider": {
              "order": [
                "minimax/lightning"
              ],
              "allow_fallbacks": false
            }
          }
        },
        "qwen/qwen3-coder-30b-a3b-instruct": {
          "options": {
            "provider": {
              "order": [
                "alibaba"
              ],
              "allow_fallbacks": false
            }
          }
        },
        "moonshotai/kimi-k2.5": {
          "options": {
            "provider": {
              "order": [
                "moonshotai"
              ],
              "allow_fallbacks": false
            }
          }
        }
      },
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    },
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "glm-4.7-flash": {
          "name": "GLM-4.7 Flash (local)",
          "limit": {
            "context": 204800,
            "output": 131072
          }
        },
        "qwen3-coder-next": {
          "name": "Qwen3 Coder Next (local)",
          "limit": {
            "context": 262144,
            "output": 131072
          }
        }
      }
    },
    "deepseek": {
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      }
    },
    "openai": {
      "options": {
        "websearch_cited": {
          "model": "gpt-5.4"
        }
      }
    },
    "google": {
      "options": {
        "websearch_cited": {
          "model": "gemini-3.1-flash"
        }
      }
    }
  }
}
